# ============================================================
# GORMARAN AI GROWTH HUB - Frontend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Firebase Configuration (from Firebase Console > Project Settings)
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id

# Stripe (Publishable Key - safe for frontend)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# Stripe Price IDs (from Stripe Dashboard > Products)
REACT_APP_STRIPE_GROW_PRICE_ID=price_your_grow_monthly_price_id
REACT_APP_STRIPE_SCALE_PRICE_ID=price_your_scale_monthly_price_id
REACT_APP_STRIPE_EVOLUTION_PRICE_ID=price_your_evolution_monthly_price_id
REACT_APP_STRIPE_N8N_ADDON_PRICE_ID=price_your_n8n_addon_price_id

# Backend API URL
REACT_APP_API_URL=http://localhost:5000

# Google Analytics Measurement ID (from GA4 > Admin > Data Streams)
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Admin UIDs — comma-separated Firebase UIDs that get full access (no Firestore subscription check)
REACT_APP_ADMIN_UIDS=uid1,uid2
