DPI = 150
SZ  = 7.2

def new_slide():
    fig = plt.figure(figsize=(SZ, SZ), dpi=DPI, facecolor=CREAM)
    ax  = fig.add_axes([0, 0, 1, 1])
    ax.set_facecolor(CREAM)
    ax.set_xlim(0, 1); ax.set_ylim(0, 1)
    ax.axis('off')
    return fig, ax

def save(fig, n):
    path = f"{OUT_DIR}/slide_{n:02d}.png"
    fig.savefig(path, dpi=DPI, bbox_inches='tight', facecolor=CREAM, pad_inches=0)
    plt.close(fig)
    print(f"  -> {path}")

def footer_line(ax):
    ax.axhline(0.07, xmin=0.07, xmax=0.93, color=LGRAY, lw=0.8, zorder=5)
    ax.text(0.5, 0.043, "@gormaran_ai_marketing",
            fontfamily=BODY, fontsize=9, color=GRAY,
            ha='center', va='center', zorder=10)

def arrow_btn(ax, x=0.88, y=0.092):
    ax.add_patch(FancyBboxPatch((x-0.055, y-0.038), 0.11, 0.076,
                                boxstyle='round,pad=0.018',
                                facecolor=WHITE, edgecolor=RED,
                                linewidth=1.2, zorder=8))
    ax.annotate('', xy=(x+0.018, y), xytext=(x-0.018, y),
                arrowprops=dict(arrowstyle='->', color=RED, lw=1.5),
                zorder=10)

def step_badge(ax, num, label, x=0.07, y=0.92):
    ax.text(x, y, num,
            fontfamily=NUM, fontsize=60, color=RED,
            ha='left', va='top', zorder=10)
    ax.text(x + 0.14, y - 0.01, label,
            fontfamily=CAPS, fontsize=20, color=BLACK,
            ha='left', va='top', zorder=10)

def red_pill(ax, text, x, y, w=0.26):
    h = 0.058
    ax.add_patch(FancyBboxPatch((x - w/2, y - h/2), w, h,
                                boxstyle='round,pad=0.022',
                                facecolor=WHITE, edgecolor=RED,
                                linewidth=1.3, zorder=8))
    ax.text(x, y, text, fontfamily=BODY_BOLD, fontsize=10,
            color=RED, ha='center', va='center', zorder=10)

def cblock(ax, lines, x, y, w, lh=0.048):
    h = len(lines) * lh + 0.036
    ax.add_patch(Rectangle((x, y - h + 0.018), w, h,
                            facecolor="#EDE8DF", edgecolor='none', zorder=5))
    ax.add_patch(Rectangle((x, y - h + 0.018), 0.006, h,
                            facecolor=RED, edgecolor='none', zorder=6))
    for i, line in enumerate(lines):
        yy = y - 0.012 - i * lh
        color = RED if line.startswith("#") else BLACK
        ax.text(x + 0.022, yy, line,
                fontfamily=MONO, fontsize=8.2, color=color,
                ha='left', va='center', zorder=7)

def pixel_mascot(ax, cx=0.5, cy=0.82, scale=0.048):
    s = scale
    def px(gx, gy, w=1, h=1, color=BLACK):
        ax.add_patch(Rectangle((cx + gx*s - s*3, cy + gy*s - s*3),
                                w*s, h*s, facecolor=color, edgecolor='none', zorder=8))
    BODY_C = "#C4855A"; BODY_D = "#A06840"; CAPE_C = "#8B3A2A"
    px(1,5, 4, 2, BODY_C)
    px(1.5,6, 1, 0.7, BLACK); px(3.5,6, 1, 0.7, BLACK)
    px(0.5,3, 5, 2, BODY_C)
    px(2,3.5, 2, 1, CAPE_C)
    ax.text(cx + 2.5*s - s*3 + s, cy + 4*s - s*3,
            "C", fontfamily=BODY_BOLD, fontsize=int(scale*90), color=WHITE,
            ha='center', va='center', zorder=9)
    px(-0.5,3, 1.5, 2, CAPE_C); px(5,3, 1.5, 2, CAPE_C)
    px(1,1, 1.5, 2, BODY_D); px(3.5,1, 1.5, 2, BODY_D)
    px(-1,2.5, 1.5, 1, BODY_D); px(5.5,2.5, 1.5, 1, BODY_D)
    px(2.8,7, 0.5, 1, BLACK)

