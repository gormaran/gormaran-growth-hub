DPI = 150   # 1080/150 = 7.2 inches
SZ  = 7.2   # inches → 1080px


def new_slide():
    fig = plt.figure(figsize=(SZ, SZ), dpi=DPI, facecolor=BG)
    ax  = fig.add_axes([0, 0, 1, 1])
    ax.set_facecolor(BG)
    ax.set_xlim(0, 1)
    ax.set_ylim(0, 1)
    ax.axis('off')
    return fig, ax

def save(fig, n):
    path = f"{OUT_DIR}/slide_{n:02d}.png"
    fig.savefig(path, dpi=DPI, bbox_inches='tight', facecolor=BG, pad_inches=0)
    plt.close(fig)
    print(f"  → {path}")

def tag(ax, text, x, y, color=BLUE):
    """Small pill tag"""
    ax.text(x, y, text, fontfamily=MONO, fontsize=9, color=color,
            ha='center', va='center', zorder=10,
            bbox=dict(boxstyle='round,pad=0.4', facecolor=BLUE_DIM,
                      edgecolor=color, linewidth=0.8, alpha=0.9))

def footer(ax, slide_num, total=7):
    """Bottom bar with brand + progress dots"""
    ax.axhline(0.065, xmin=0.06, xmax=0.94, color=GRAY, lw=0.5, alpha=0.3, zorder=5)
    ax.text(0.06, 0.038, "gormaran.io", fontfamily=BOLD, fontsize=9,
            color=GRAY, alpha=0.55, ha='left', va='center', zorder=10)
    # progress dots
    dot_x_start = 0.72
    for i in range(1, total+1):
        x = dot_x_start + (i-1) * 0.038
        if i == slide_num:
            ax.plot(x, 0.038, 'o', color=BLUE, ms=5, zorder=10)
        else:
            ax.plot(x, 0.038, 'o', color=GRAY, ms=3, alpha=0.35, zorder=10)

def code_block(ax, lines, x, y, w, line_h=0.052):
    """Render a fake code block"""
    h = len(lines) * line_h + 0.04
    ax.add_patch(FancyBboxPatch((x, y - h + 0.02), w, h,
                                boxstyle='round,pad=0.015',
                                facecolor='#0A0A12', edgecolor=BLUE_DIM,
                                linewidth=1, zorder=6))
    # dot bar
    for i, col in enumerate([GREEN, AMBER, "#FF5F57"]):
        ax.plot(x + 0.03 + i*0.025, y - 0.01, 'o', color=col, ms=4, zorder=8)
    for i, line in enumerate(lines):
        yy = y - 0.04 - i * line_h
        ax.text(x + 0.03, yy, line, fontfamily=MONO, fontsize=8.5,
                color=WHITE, alpha=0.88, ha='left', va='center', zorder=8)

