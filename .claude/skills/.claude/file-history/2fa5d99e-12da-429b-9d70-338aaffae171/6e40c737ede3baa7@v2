def new_slide():
    fig = plt.figure(figsize=(SZ, SZ), dpi=DPI, facecolor=CREAM)
    ax  = fig.add_axes([0, 0, 1, 1])
    ax.set_facecolor(CREAM)
    ax.set_xlim(0, 1); ax.set_ylim(0, 1)
    ax.axis('off')
    return fig, ax

def save(fig, n):
    path = f"{OUT_DIR}/slide_{n:02d}.png"
    fig.savefig(path, dpi=DPI, bbox_inches='tight', facecolor=CREAM, pad_inches=0)
    plt.close(fig)
    print(f"  -> {path}")

def footer_line(ax):
    ax.axhline(0.068, xmin=0.07, xmax=0.93, color=LGRAY, lw=0.8, zorder=5)
    ax.text(0.5, 0.040, "@gormaran_ai_marketing",
            fontfamily=BODY, fontsize=9, color=GRAY,
            ha='center', va='center', zorder=10)

def arrow_btn(ax, x=0.88, y=0.092):
    ax.add_patch(FancyBboxPatch((x-0.055, y-0.038), 0.11, 0.076,
                                boxstyle='round,pad=0.018',
                                facecolor=WHITE, edgecolor=RED,
                                linewidth=1.2, zorder=8))
    ax.annotate('', xy=(x+0.018, y), xytext=(x-0.018, y),
                arrowprops=dict(arrowstyle='->', color=RED, lw=1.5),
                zorder=10)

def slide_number(ax, current, total=7):
    ax.text(0.07, 0.040, f"{current}/{total}",
            fontfamily=BODY, fontsize=9, color=LGRAY,
            ha='left', va='center', zorder=10)

def top_label(ax, text):
    ax.text(0.07, 0.943, text,
            fontfamily=CAPS, fontsize=11, color=RED,
            ha='left', va='top', zorder=10)

def divider(ax, y, xmin=0.07, xmax=0.93):
    ax.axhline(y, xmin=xmin, xmax=xmax, color=LGRAY, lw=0.8, zorder=5)

def bullet_row(ax, icon_color, text, bold_part, y, x=0.07):
    ax.add_patch(Rectangle((x, y - 0.010), 0.018, 0.018,
                            facecolor=icon_color, edgecolor='none', zorder=7))
    ax.text(x + 0.035, y + 0.001, bold_part,
            fontfamily=BODY_BOLD, fontsize=11, color=BLACK,
            ha='left', va='center', zorder=10)
    if text:
        ax.text(x + 0.035, y - 0.028, text,
                fontfamily=BODY, fontsize=9.5, color=GRAY,
                ha='left', va='center', zorder=10)

def vs_pill(ax, label_a, label_b, x=0.5, y=0.88, w=0.78):
    half = w / 2
    h = 0.054
    # A side — red
    ax.add_patch(FancyBboxPatch((x - half, y - h/2), half, h,
                                boxstyle='round,pad=0',
                                facecolor=RED, edgecolor='none', zorder=6))
    ax.text(x - half/2, y, label_a,
            fontfamily=BODY_BOLD, fontsize=10, color=WHITE,
            ha='center', va='center', zorder=8)
    # B side — black
    ax.add_patch(FancyBboxPatch((x, y - h/2), half, h,
                                boxstyle='round,pad=0',
                                facecolor=OFFBLACK, edgecolor='none', zorder=6))
    ax.text(x + half/2, y, label_b,
            fontfamily=BODY_BOLD, fontsize=10, color=WHITE,
            ha='center', va='center', zorder=8)


