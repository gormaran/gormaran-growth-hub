.automations {
  max-width: 860px;
  margin: 0 auto;
  padding: 2.5rem 1.5rem 4rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

/* Header */
.automations__header {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}

.automations__title {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 900;
  margin-bottom: 0.4rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.automations__title-icon {
  background: var(--gradient-primary);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.automations__subtitle {
  font-size: 1rem;
  color: var(--text-muted);
}

/* Chat card */
.automations__chat-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-color);
  border-radius: var(--border-radius-xl);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-height: 460px;
  max-height: 560px;
  box-shadow: var(--shadow-md);
}

/* Messages */
.automations__messages {
  flex: 1;
  overflow-y: auto;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.automations__msg {
  display: flex;
  align-items: flex-end;
  gap: 0.6rem;
}

.automations__msg--user {
  flex-direction: row-reverse;
}

.automations__avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85rem;
  flex-shrink: 0;
}

.automations__bubble {
  max-width: 72%;
  padding: 0.75rem 1rem;
  border-radius: 18px;
  font-size: 0.925rem;
  line-height: 1.55;
  white-space: pre-wrap;
}

.automations__msg--assistant .automations__bubble {
  background: var(--bg-surface-2);
  border: 1px solid var(--border-color);
  border-bottom-left-radius: 4px;
  color: var(--text-primary);
}

.automations__msg--user .automations__bubble {
  background: var(--gradient-primary);
  border-bottom-right-radius: 4px;
  color: #fff;
}

/* Typing indicator */
.automations__bubble--typing {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 0.85rem 1rem;
}

.automations__bubble--typing span {
  display: block;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--text-muted);
  animation: bounce 1.2s infinite ease-in-out;
}

.automations__bubble--typing span:nth-child(2) { animation-delay: 0.2s; }
.automations__bubble--typing span:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-6px); }
}

/* Input row */
.automations__input-row {
  display: flex;
  gap: 0.75rem;
  padding: 1rem 1.25rem;
  border-top: 1px solid var(--border-color);
  background: var(--bg-surface);
}

.automations__input {
  flex: 1;
  background: var(--bg-surface-2);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  color: var(--text-primary);
  font-size: 0.925rem;
  padding: 0.7rem 1rem;
  outline: none;
  transition: border-color var(--transition);
  font-family: var(--font-sans);
}

.automations__input::placeholder { color: var(--text-muted); }

.automations__input:focus {
  border-color: var(--color-primary);
}

.automations__input:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.automations__send {
  background: var(--gradient-primary);
  color: #fff;
  border: none;
  border-radius: 12px;
  padding: 0.7rem 1.4rem;
  font-size: 0.925rem;
  font-weight: 600;
  cursor: pointer;
  transition: opacity var(--transition);
  font-family: var(--font-sans);
}

.automations__send:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.automations__send:not(:disabled):hover { opacity: 0.85; }

/* Example chips */
.automations__examples {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.automations__examples-label {
  font-size: 0.8rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.automations__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.automations__chip {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: 20px;
  color: var(--text-secondary);
  font-size: 0.825rem;
  padding: 0.4rem 0.9rem;
  cursor: pointer;
  transition: border-color var(--transition), color var(--transition);
  font-family: var(--font-sans);
}

.automations__chip:hover:not(:disabled) {
  border-color: var(--color-primary);
  color: var(--text-primary);
}

.automations__chip:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

@media (max-width: 600px) {
  .automations { padding: 1.5rem 1rem 3rem; }
  .automations__bubble { max-width: 88%; }
}
