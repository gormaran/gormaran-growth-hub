  ["PASS", "WARN", "FAIL"].forEach((st, i) => {
    const lx = 0.35 + i * 1.2;
    s.addShape(pres.shapes.RECTANGLE, {
      x: lx, y: 5.3, w: 0.16, h: 0.16,
